# ─────────────────────────────────────────────
#  EXIRACKS — Frontend · variables de entorno
#  Copia como ".env" (Vite expone solo las que empiezan con VITE_)
# ─────────────────────────────────────────────

# URL base del API. En dev se deja vacío y Vite hace proxy a localhost:4000.
# En producción (Vercel) pon la URL pública del backend en Railway, ej:
# VITE_API_URL=https://exiracks-backend.up.railway.app/api
VITE_API_URL=/api

# WhatsApp del negocio para el botón flotante (formato internacional sin "+").
VITE_WHATSAPP_NUMBER=526620000000

# (Opcional) target del proxy en dev si tu backend no está en 4000
# VITE_PROXY_TARGET=http://localhost:4000
