# ───────────────────────────────────────────────────────────────
#  EXIRACKS — Backend · variables de entorno
#  Copia este archivo como ".env" y llena los valores reales.
# ───────────────────────────────────────────────────────────────

# Puerto del servidor
PORT=4000

# URL pública del frontend (para CORS y para construir los links de retorno de pago)
FRONTEND_URL=http://localhost:5173

# URL pública de ESTE backend (para el webhook de Mercado Pago en producción)
BACKEND_URL=http://localhost:4000

# ── Base de datos (PostgreSQL) ──────────────────────────────────
# Local con docker-compose (ver README):
DATABASE_URL="postgresql://exiracks:exiracks@localhost:5432/exiracks?schema=public"
# En Railway pega aquí la "DATABASE_URL" que te da el plugin de Postgres.

# ── Mercado Pago (Checkout Pro) ─────────────────────────────────
# PENDIENTE: pon tus credenciales. Mientras estén vacías, el checkout
# corre en MODO DEMO (crea el pedido pero no cobra de verdad).
# Las consigues en https://www.mercadopago.com.mx/developers/panel
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ── Correo de confirmación ──────────────────────────────────────
# MAIL_PROVIDER: "resend" | "smtp" | "none"  (none = solo log en consola)
MAIL_PROVIDER=none
MAIL_FROM="Exiracks <ventas@tudominio.com>"
# Si usas Resend (https://resend.com):
RESEND_API_KEY=
# Si usas SMTP (Nodemailer):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── WhatsApp del negocio (para el link wa.me prellenado) ────────
# Formato internacional sin "+" ni espacios. Ej: 526621234567
BUSINESS_WHATSAPP=526620000000

# ── Panel de administración (/admin) ────────────────────────────
ADMIN_EMAIL=admin@exiracks.com
ADMIN_PASSWORD=cambiame123
JWT_SECRET=pon-aqui-una-cadena-larga-y-secreta

# ── Impuestos / negocio ─────────────────────────────────────────
# IVA que se suma SOLO cuando el cliente pide factura (0.16 = 16%)
IVA_RATE=0.16
